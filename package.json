{
  "name": "sonos-blockchain",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=.env --watch src/index.ts",
    "start": "bun --env-file=.env src/index.ts",
    "generate-keys": "bun run scripts/generate-keys.ts",
    "create-token": "bun --env-file=.env run scripts/create-token.ts",
    "create-topics": "bun --env-file=.env run scripts/create-topics.ts",
    "test": "bun test tests/blockchain.test.ts",
    "test:storage": "bun test tests/storage.test.ts",
    "test:all": "bun test tests/",
    "test:0g-upload": "bun --env-file=.env run scripts/test-0g-upload.ts",
    "test:0g-download": "bun --env-file=.env run scripts/test-0g-download.ts",
    "test:hedera-client": "bun --env-file=.env run scripts/test-hedera-client.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.1",
    "@hashgraph/sdk": "^2.81.0",
    "ethers": "^6.16.0",
    "hono": "^4.12.10",
    "viem": "^2.47.10"
  }
}
